# CA Manager Demo configuration
# Copy this file to .env and change the secrets before running docker compose up -d.

# Replace with the Docker Hub image you publish from the private CA-Manager repo.
CA_MANAGER_DEMO_IMAGE=apimonster/ca-manager-demo:latest

# Host port for the demo UI and API.
CA_MANAGER_DEMO_PORT=8585

# Demo runtime secrets. Use long random values for anything shared beyond your laptop.
SESSION_SECRET=change-this-demo-session-secret-at-least-32-characters
KEY_ENCRYPTION_SECRET=change-this-demo-key-secret-at-least-32-characters
MYSQL_ROOT_PASSWORD=change-this-demo-root-password
MYSQL_PASSWORD=change-this-demo-db-password

# Required for browser login over plain http://localhost:8585.
SESSION_COOKIE_SECURE=false

# Set to false to initialize a blank schema instead of loading Acme Corp demo data.
CA_MANAGER_DEMO_SEED=true

# Pre-created demo administrator. Change these before sharing a persistent demo.
CA_MANAGER_DEMO_ADMIN_EMAIL=admin@acme.com
CA_MANAGER_DEMO_ADMIN_PASSWORD=ChangeMe!8585
CA_MANAGER_DEMO_ADMIN_NAME=Acme Demo Admin
